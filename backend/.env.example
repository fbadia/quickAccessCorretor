# Supabase — usar credenciais do projeto de cada ambiente
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Google Gemini AI
GEMINI_API_KEY=sua_gemini_api_key_aqui

# Google Drive (opcional, se usar sync via Drive)
GOOGLE_DRIVE_FOLDER_ID=seu_folder_id_aqui
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Porta do servidor (opcional — padrão 3001, Render usa PORT automático)
PORT=3001
